      "id": "renderer_renderer_gamerenderer",
      "label": "GameRenderer",
      "file_type": "code",
      "source_file": "renderer/Renderer.ts",
      "rationale": "Strictly paints pixels. It does not mutate world state. Uses a pre-allocated renderBuffer to prevent Garbage Collection (GC) micro-stutters during the 60fps loop."
    },
    {
      "id": "renderer_renderer_zerogcbuffer",
      "label": "Zero-GC Buffer",
      "file_type": "concept",
      "source_file": "renderer/Renderer.ts",
      "rationale": "Avoids allocating a new array via .filter() or .concat() every frame by using a pre-allocated array and nulling trailing indices."
    },
    {
      "id": "renderer_baker_bakecreaturesprites",
      "label": "bakeCreatureSprites",
      "file_type": "code",
      "source_file": "renderer/baker.ts",
      "rationale": "Bakes the base body pixels and SVG decals into 4 discrete state frames. Must enforce DPR=1 to avoid Retina mobile memory crash."
    },
